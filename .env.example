# ---------------------------------------------------------------
# RxTracker Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# ---------------------------------------------------------------

# Timezone — must match the timezone your dose times are entered in.
# See https://www.php.net/manual/en/timezones.php for valid identifiers.
APP_TIMEZONE=America/New_York

# Database (defaults match a fresh XAMPP install — change if needed)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rx_tracker
DB_USERNAME=root
DB_PASSWORD=

# Web Push / VAPID keys
# Generate these once by running:  php scripts/generate_vapid_keys.php
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:you@example.com

# Email (Resend API — https://resend.com)
# Used for password reset emails only.
RESEND_API_KEY=re_...
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=RxTracker

# App public URL (used to build reset links in emails)
APP_URL=https://rx-tracker.dwdrm.com

# Google Sign-In (OAuth Client ID) — https://console.cloud.google.com/apis/credentials
# Leave blank to hide the "Sign in with Google" button.
GOOGLE_CLIENT_ID=
